@page "/products"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<PageTitle>Products</PageTitle>
<h1>Products</h1>

<div class="mb-3 d-flex gap-2">
    <a class="btn btn-primary" href="products/create">New Product</a>
    <a class="btn btn-secondary" href="products/import">Import</a>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_products is null)
{
    <p>Loading…</p>
}
else if (_products.Count == 0)
{
    <p class="text-muted">No products found.</p>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Category</th>
                <th>Active</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in _products)
            {
                <tr>
                    <td>@p.Code</td>
                    <td>@p.Name</td>
                    <td>@((Category)p.Category)</td>
                    <td>@(p.IsActive ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" href="products/@p.Id">View</a>
                        <a class="btn btn-sm btn-outline-primary ms-1" href="products/@p.Id/edit">Edit</a>
                        <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteAsync(p.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    List<ProductDto>? _products;
    string? _error;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("ProductApi");
        _products = await client.GetFromJsonAsync<List<ProductDto>>("api/products");
    }

    async Task DeleteAsync(Guid id)
    {
        _error = null;
        var client = HttpClientFactory.CreateClient("ProductApi");
        var response = await client.DeleteAsync($"api/products/{id}");
        if (response.IsSuccessStatusCode)
            _products = _products?.Where(p => p.Id != id).ToList();
        else
            _error = "Delete failed.";
    }
}
